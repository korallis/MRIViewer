{
  "name": "mriviewer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Open-source, local-only web app for viewing MRI DICOM studies as interactive 3D volume renders",
  "license": "MIT",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tools",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "phantom": "tsx tools/make-phantom.ts",
    "check": "npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "comlink": "4.4.2",
    "dcmjs": "0.52.0",
    "dicom-parser": "1.8.21",
    "pako": "2.1.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "three": "0.185.1",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@playwright/test": "^1.53.0",
    "@types/node": "^24.0.0",
    "@types/pako": "^2.0.3",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.30.0",
    "prettier": "^3.6.0",
    "tsx": "^4.20.0",
    "typescript": "~5.8.0",
    "typescript-eslint": "^8.35.0",
    "vite": "8.1.3",
    "vitest": "^3.2.0"
  }
}
