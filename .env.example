# Optional AI companion (opt-in). Without these, MRIViewer runs fully local
# with zero network calls. Copy to .env.local and fill in to enable the
# evidence companion. The LLM call happens server-side in the Vite dev/preview
# process — the browser only ever talks to localhost, and only DE-IDENTIFIED
# technical study context is sent (no patient identifiers, no pixel data).

# Vercel AI Gateway key (has a Zero Data Retention agreement in this deployment).
AI_GATEWAY_API_KEY=

# Optional overrides:
# AI_GATEWAY_BASE=https://ai-gateway.vercel.sh/v1
# MRIVIEWER_AI_MODEL=anthropic/claude-opus-4.8
